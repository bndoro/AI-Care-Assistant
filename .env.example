# ── Server ──────────────────────────────────────────
PORT=3001

# ── AI Provider ─────────────────────────────────────
# Set ONE of: openai | gemini | claude | mock
AI_PROVIDER=mock

OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-1.5-flash

ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-3-haiku-20240307

# ── Firebase ─────────────────────────────────────────
# Copy these from Firebase Console → Project Settings → Your Apps → Web App
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_DATABASE_URL=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# ── Feature flags ────────────────────────────────────
ENABLE_VOICE_API=true
ENABLE_ESCALATION_WEBHOOKS=false

# ── Notifications (optional) ─────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
CAREGIVER_PHONE=
